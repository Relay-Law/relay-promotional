# Waitlist storage (app/api/waitlist/route.ts) + rate limiting (lib/ratelimit.ts).
# Rate limiting reuses this same Redis — no separate limiter service/keys needed. If unset,
# limiting fails OPEN (requests are allowed), so protection is only active when this is configured.
RELAY_REDIS_URL=

# ─── Billing / Licensing ────────────────────────────────────────────────────
# Public base URL of this site, e.g. https://relay-law.com (used for Checkout redirects)
NEXT_PUBLIC_APP_URL=

# Stripe — https://dashboard.stripe.com/apikeys (use test keys while developing)
STRIPE_SECRET_KEY=
# Stripe → Developers → Webhooks → your endpoint's signing secret (whsec_...).
# Locally, `stripe listen` prints this secret.
STRIPE_WEBHOOK_SECRET=
# The recurring per-seat Price id (price_...) from Stripe → Products.
STRIPE_PRICE_ID=
# Free-trial length in days (0 to disable). Defaults to 14 if unset. The trial clock starts at
# ACTIVATION (POST /api/admin/activate), not at signup.
STRIPE_TRIAL_DAYS=14

# Admin secret for the internal activation hook (POST /api/admin/activate). Only we call it,
# the day a firm's server is installed & verified. Generate a long random string.
ADMIN_API_KEY=

# ─── Bot protection: Cloudflare Turnstile (optional) ────────────────────────
# Guards the public waitlist form. If UNSET, verification is skipped (form works as before) —
# it only starts enforcing once the SECRET below is present. Create a widget at
# https://dash.cloudflare.com → Turnstile.
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY — the SITE key (public, shipped to the browser).
#   TURNSTILE_SECRET_KEY           — the SECRET key (server-only; enables enforcement).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Signup confirmation email (Resend) ─────────────────────────────────────
# Optional — if unset, no confirmation email is sent (signup still works).
# Get an API key at https://resend.com. For testing you can leave EMAIL_FROM unset
# (uses onboarding@resend.dev, which only delivers to your own Resend account email).
RESEND_API_KEY=
EMAIL_FROM=Relay <onboarding@resend.dev>

# ─── Hardware financing (lease) ─────────────────────────────────────────────
# We front a workstation and the firm repays it over N months at a flat rate.
# This is a speed/convenience play, not a margin play (rate ~= fees + capital cost).
HARDWARE_DEFAULT_CENTS=80000   # reference machine cost in cents ($800)
HARDWARE_LEASE_MONTHS=6         # number of monthly payments
HARDWARE_LEASE_RATE=0.10        # flat rate over the whole term (0.10 = 10%)

# License signing keypair (RS256 — required by relay-api's licensing.py). Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out license_private.pem
#   openssl rsa -in license_private.pem -pubout -out license_public.pem
# LICENSE_SIGNING_KEY = the PRIVATE key PEM (this site mints licenses).
# Put the PUBLIC key PEM in relay-api at /app/keys/license_public.pem (RELAY_LICENSE_PUBKEY_PATH).
# In .env files, paste the PEM with literal \n escapes OR use a multiline value per your host.
LICENSE_SIGNING_KEY=
# Only needed if you want this site to self-verify licenses (e.g. tests). Optional in prod.
LICENSE_PUBLIC_KEY=

# ─── Ops dashboard — Google SSO (Auth.js / next-auth v5) ─────────────────────
# Gates /ops and /api/ops. The public marketing site is unaffected.
#
# AUTH_SECRET: signs the session cookie. Generate one with:  npx auth secret
# (or: openssl rand -base64 33). Required.
AUTH_SECRET=
# Google OAuth client (see setup steps). Auth.js reads these two names automatically.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# WHO may sign in. Set at least ONE of these, or every sign-in is denied (fail closed).
#   OPS_ALLOWED_DOMAIN — any verified @domain Google account (your Workspace), e.g. relay-law.com
#   OPS_ALLOWED_EMAILS — comma-separated explicit allow-list, e.g. you@gmail.com,cofounder@gmail.com
OPS_ALLOWED_DOMAIN=
OPS_ALLOWED_EMAILS=
